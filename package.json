{
  "name": "@dancingmusic/music-connect-radio",
  "version": "0.1.2",
  "description": "Internet Radio music connector for DancingMusic. Backed by the Radio Browser community catalog (radio-browser.info).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --target es2020 --no-splitting",
    "prepublishOnly": "npm run build",
    "test": "vitest run --reporter=verbose"
  },
  "keywords": [
    "dancingmusic",
    "music-connector",
    "internet-radio"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@dancingmusic/music-connect": ">=0.2.0"
  },
  "devDependencies": {
    "@dancingmusic/music-connect": "github:DancingMusic/MusicConnect#b90bcabdeff428eb1b1bf5a772c40f2c5e4f5013",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
